{
  "__inputs": [],
  "__requires": [],
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "rate(http_requests_total[1m])", "legendFormat": "{{method}} {{handler}}"}],
      "datasource": "Prometheus"
    },
    {
      "id": 2,
      "title": "Latency p99",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{"expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p99"}],
      "datasource": "Prometheus"
    },
    {
      "id": 3,
      "title": "LLM Tokens / min",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [{"expr": "rate(llm_tokens_total[1m])", "legendFormat": "{{type}}"}],
      "datasource": "Prometheus"
    },
    {
      "id": 4,
      "title": "Active Sessions",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8},
      "targets": [{"expr": "active_sessions", "legendFormat": "Sessions"}],
      "datasource": "Prometheus"
    },
    {
      "id": 5,
      "title": "Security Blocks",
      "type": "timeseries",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 8},
      "targets": [{"expr": "rate(security_blocks_total[5m])", "legendFormat": "{{reason}}"}],
      "datasource": "Prometheus"
    },
    {
      "id": 6,
      "title": "Top Tools Used",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [{"expr": "topk(5, tool_calls_total)", "legendFormat": "{{tool_name}}"}],
      "datasource": "Prometheus"
    },
    {
      "id": 7,
      "title": "Projected Monthly Token Cost (USD)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 16},
      "targets": [{"expr": "rate(llm_tokens_total[1h]) * 24 * 30 * 0.0000003", "legendFormat": "Projected Cost"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}},
      "datasource": "Prometheus"
    },
    {
      "id": 8,
      "title": "LLM Fallback Events",
      "type": "stat",
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 20},
      "targets": [{"expr": "llm_fallback_total", "legendFormat": "Fallbacks"}],
      "datasource": "Prometheus"
    }
  ],
  "schemaVersion": 38,
  "tags": ["walter-ai", "aiops"],
  "title": "Walter AI — AIOps Dashboard",
  "uid": "walter-ai-aiops",
  "version": 1
}
